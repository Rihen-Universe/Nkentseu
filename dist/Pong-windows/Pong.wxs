    </Feature>
    <CustomAction Id="Nk_FirewallAdd" Directory="INSTALLDIR" ExeCommand="netsh advfirewall firewall add rule name=&quot;Pong (Network)&quot; dir=in action=allow program=&quot;[#ExeFile]&quot; enable=yes profile=any" Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="Nk_FirewallDel" Directory="INSTALLDIR" ExeCommand="netsh advfirewall firewall delete rule name=&quot;Pong (Network)&quot;" Execute="deferred" Impersonate="no" Return="ignore" />
    <InstallExecuteSequence>
      <Custom Action="Nk_FirewallAdd" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="Nk_FirewallDel" Before="RemoveFiles" Condition="Installed AND REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>