#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""Mu - plateforme de jeux educatifs maternelle (3-5 ans) sur NKCanvas.

Equivalent de Nkoung mais pour les tout-petits : couleurs, compter, calculs.
Nom "Mu" = enfant en ghomala' (bamileke, Cameroun).
"""

from Jenga import *
from jengaconfig import *
from Jenga.Core.Api import androidallowrotation
import os
import shutil
import subprocess


def _pkg_exists(pkg_name):
    if not shutil.which("pkg-config"):
        return False
    try:
        return subprocess.call(
            ["pkg-config", "--exists", pkg_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ) == 0
    except Exception:
        return False


def _norm(path):
    return path.replace("\\", "/") if path else path


_VULKAN_SDK = _norm(os.getenv("VULKAN_SDK", ""))
_VULKAN_INCLUDE = _norm(os.path.join(_VULKAN_SDK, "Include")) if _VULKAN_SDK else ""
_VULKAN_LIB = _norm(os.path.join(_VULKAN_SDK, "Lib")) if _VULKAN_SDK else ""
_VULKAN_OPT = os.getenv("NK_ENABLE_VULKAN", "auto").strip().lower()
if _VULKAN_OPT in ("0", "false", "off", "no"):
    _WANT_VULKAN = False
elif _VULKAN_OPT in ("1", "true", "on", "yes"):
    _WANT_VULKAN = True
else:
    _WANT_VULKAN = bool(_VULKAN_INCLUDE) or _pkg_exists("vulkan")

# Le backend Vulkan ne doit etre defini QUE sur les plateformes ou il est cable
# (Windows / Android / HarmonyOS). Ailleurs (Web/Linux-GL/macOS), il reste a 0 :
# sinon le code de Mou reference NkVulkanContext absent de ces libs -> link casse.
_VK_ON  = f"NKENTSEU_ENABLE_VULKAN_BACKEND={1 if _WANT_VULKAN else 0}"
_VK_OFF = "NKENTSEU_ENABLE_VULKAN_BACKEND=0"

_WAYLAND_LINKS = ["pthread", "wayland-client", "wayland-egl", "xkbcommon", "wayland-cursor", "EGL", "GLESv2"]
_WAYLAND_DEFINES = ["NKENTSEU_FORCE_WINDOWING_WAYLAND_ONLY"]
if _pkg_exists("libdecor-0"):
    _WAYLAND_LINKS.append("decor-0")
    _WAYLAND_DEFINES.append("NKENTSEU_WAYLAND_LIBDECOR")


with project("Mou"):
    windowedapp()
    language("C++")
    cppdialect("C++17")
    location(".")

    files(["src/**.cpp"])

    # Assets (svg/levels/voice/sfx) : embarques dans l'APK Android + copies sur desktop.
    # NkFile lit depuis l'AAssetManager sur Android (cf. androidassets ci-dessous).
    dependfiles(["assets"])

    nkentseudependson(
        ["NKEvent", "NKWindow", "NKCanvas", "NKImage", "NKFont", "NKGlad", "NKLogger",
         "NKMath", "NKTime", "NKStream", "NKUI", "NKFileSystem", "NKSerialization",
         "NKContainers", "NKMemory", "NKCore", "NKPlatform", "NKThreading", "NKAudio"],
        extra_includes=["src/Mou", "src", "%{NKGlad.location}/include", "%{wks.location}/Externals"]
                       + ([_VULKAN_INCLUDE] if _VULKAN_INCLUDE else []),
        # NKENTSEU_ENABLE_VULKAN_BACKEND est defini par plateforme ci-dessous
        # (uniquement la ou Vulkan est cable), pas globalement.
    )

    objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
    targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")

    apppublisher("Rihen Universe")
    appversion("0.1.0")
    licensefile("../../LICENSE")

    # Icone d'application (cross-platform). Jenga genere : Android res/mipmap-*,
    # desktop .ico/.png, iOS CFBundleIconFile, Web favicon. Source = mascotte Nana
    # ("mu" = enfant en ghomala'). Genere via Resources/gen_icon.ps1 (GDI+).
    appicon("Resources/mou_icon.png")

    with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
        windowedapp()
        usetoolchain(TC_WINDOWS)
        defines(["WIN32_LEAN_AND_MEAN", "_UNICODE", "UNICODE", _VK_ON])
        if _VULKAN_LIB:
            libdirs([_VULKAN_LIB])
        _WIN_LINKS = [
            "user32", "gdi32", "opengl32", "dwmapi", "shell32",
            "mf", "mfplat", "mfreadwrite", "mfuuid",
            "uuid", "ole32", "dinput8", "dxguid",
            "d3d11", "d3d12", "dxgi", "d3dcompiler",
            "avrt", "winmm",   # NKAudio (WASAPI / MMCSS)
        ]
        if _WANT_VULKAN:
            _WIN_LINKS.append("vulkan-1")
        links(_WIN_LINKS)

    with filter("system:Linux && options:linux-backend=headless || system:Linux && options:headless"):
        windowedapp()
        usetoolchain("clang-native")
        # Suffixe -headless : binaire distinct des autres backends Linux
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
        targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
        defines(["NKENTSEU_FORCE_WINDOWING_NOOP_ONLY", _VK_OFF])
        links(["pthread"])

    with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
        windowedapp()
        usetoolchain("clang-native")
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xlib/%{prj.name}")
        targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-xlib/%{prj.name}")
        defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY", _VK_ON])
        # Xrandr : moniteurs/DPI (NkXLibWindow/EventSystem) ; asound : NKAudio (ALSA)
        links(["pthread", "X11", "Xext", "Xrandr", "GL", "asound"] + (["vulkan"] if _WANT_VULKAN else []))

    with filter("system:Linux && options:linux-backend=xcb"):
        windowedapp()
        usetoolchain("clang-native")
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
        targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
        defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY", _VK_ON])
        links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11", "X11-xcb", "Xext", "xkbcommon", "xkbcommon-x11", "GL", "asound"] + (["vulkan"] if _WANT_VULKAN else []))
        ldflags(["-fuse-ld=lld"])

    with filter("system:Linux && options:linux-backend=wayland"):
        windowedapp()
        usetoolchain("clang-native")
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
        targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
        defines(_WAYLAND_DEFINES + [_VK_ON])
        links(_WAYLAND_LINKS + ["asound"] + (["vulkan"] if _WANT_VULKAN else []))

    with filter("system:macOS"):
        windowedapp()
        usetoolchain("clang-native")
        defines([_VK_OFF])
        frameworks(["Cocoa", "QuartzCore", "OpenGL"])

    with filter("system:Android"):
        windowedapp()
        usetoolchain("android-ndk")
        androidapplicationid("com.nkentseu.mou")
        androidisgame(True)
        androidminsdk(24)
        androidtargetsdk(34)
        androidcompilesdk(34)
        androidabis(["armeabi-v7a", "arm64-v8a", "x86", "x86_64"])
        androidnativeactivity(True)
        androidscreenorientation("landscape")  # toujours paysage (2 sens), jamais portrait
        androidallowrotation(False)
        androidstl("c++_shared")
        defines([_VK_ON])
        androidassets(["assets"])   # embarque Applications/Mou/assets/ dans l'APK (assets/)
        # OpenSLES + dl requis par NKAudio sur Android
        _ANDROID_LINKS = ["android", "log", "EGL", "GLESv3", "dl", "OpenSLES"]
        if _WANT_VULKAN:
            _ANDROID_LINKS.append("vulkan")
        links(_ANDROID_LINKS)

    with filter("system:HarmonyOS"):
        windowedapp()
        usetoolchain("ohos-ndk")
        harmonybundlename("com.nkentseu.mou")
        harmonyminsdk(12)
        harmonytargetapi(12)
        defines([_VK_ON])
        links(["hilog_ndk.z", "EGL", "GLESv3", "vulkan"])

    with filter("system:Web"):
        consoleapp()
        usetoolchain("emscripten")
        defines(["NKENTSEU_ENABLE_EMSCRIPTEN", _VK_OFF])
        emscriptenshellfile("web/emscripten_fullscreen_nofavicon.html")
        emscriptencanvasid("canvas")
        emscripteninitialmemory(32)
        emscriptenextraflags([
            "-s", "ASYNCIFY",
            "-s", "ALLOW_MEMORY_GROWTH=1",
            "-s", "FULL_ES3=1",
            "-s", "USE_WEBGL2=1",
            "-s", "NO_EXIT_RUNTIME=1",
        ])

    with filter("config:Debug"):
        defines(["_DEBUG", "DEBUG"])
        optimize("Off")
        symbols(True)

    with filter("config:Release"):
        defines(["NDEBUG"])
        optimize("Speed")
        symbols(False)
