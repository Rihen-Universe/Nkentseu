#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
ImGui — Dear ImGui (ocornut) compile comme bibliotheque statique pour Nkentseu/Jenga.
Coeur uniquement (aucun imgui_impl_* : le rendu se fait via les backends Nkentseu
NkImGuiCanvasBackend / NkImGuiRHIBackend, cote moteur).

Usage :
    dependson(["ImGui"]); includedirs(["%{ImGui.location}"]); links(["ImGui"])
"""
from Jenga import *

with project("ImGui"):
    staticlib()
    language("C++")
    cppdialect("C++17")
    location(".")

    includedirs(["."])

    files([
        "imgui.cpp",
        "imgui_draw.cpp",
        "imgui_tables.cpp",
        "imgui_widgets.cpp",
        "imgui_demo.cpp",
    ])

    objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
    targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}")

    with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
        usetoolchain("nk-windows-clang-mingw")
    with filter("system:Android"):
        usetoolchain("android-ndk"); buildoptions(["-fPIC"])
    with filter("system:Web"):
        usetoolchain("emscripten")
    with filter("system:macOS"):
        usetoolchain("clang-native")

    with filter("config:Debug"):
        defines(["_DEBUG"]); optimize("Off"); symbols(True)
    with filter("config:Release"):
        defines(["NDEBUG"]); optimize("Speed"); symbols(False)
