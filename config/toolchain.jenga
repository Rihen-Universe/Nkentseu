#!/usr/bin/env python3
# -*- coding: utf-8 -*-

from Jenga import *
from jengaconfig import *                                         # noqa: F401, F403
try:
    from Jenga import ProjectKind, kindexport, defines      # noqa: F811
except ImportError:
    pass  # Résolu à l'exécution par le runtime Jenga

from Jenga.GlobalToolchains import RegisterJengaGlobalToolchains

# Nom du toolchain Windows clang-mingw
TC_WINDOWS = "nk-windows-clang-mingw"

def nkentseutoolchain():
    RegisterJengaGlobalToolchains()

    # Enregistrement du toolchain Windows avec resolution explicite du compilateur
    if os.name == "nt":
        _clang = shutil.which("clang")
        _clangxx = shutil.which("clang++")
        _llvm_ar = shutil.which("llvm-ar") or shutil.which("ar")
        if not _clang and os.path.exists(r"C:\msys64\ucrt64\bin\clang.exe"):
            _clang = r"C:\msys64\ucrt64\bin\clang.exe"
        if not _clangxx and os.path.exists(r"C:\msys64\ucrt64\bin\clang++.exe"):
            _clangxx = r"C:\msys64\ucrt64\bin\clang++.exe"
        if not _llvm_ar and os.path.exists(r"C:\msys64\ucrt64\bin\llvm-ar.exe"):
            _llvm_ar = r"C:\msys64\ucrt64\bin\llvm-ar.exe"
        if not _llvm_ar and os.path.exists(r"C:\msys64\ucrt64\bin\ar.exe"):
            _llvm_ar = r"C:\msys64\ucrt64\bin\ar.exe"

        with toolchain(TC_WINDOWS, "clang"):
            settarget("Windows", "x86_64", "mingw")
            targettriple(r"x86_64-w64-windows-gnu")
            ccompiler(_clang or "clang")
            cppcompiler(_clangxx or "clang++")
            linker(_clangxx or "clang++")
            if _llvm_ar:
                archiver(_llvm_ar)
            cflags([
                "--target=x86_64-w64-windows-gnu",
                "-DWINVER=0x0601",
                "-D_WIN32_WINNT=0x0601",
            ])
            cxxflags([
                "--target=x86_64-w64-windows-gnu",
                "-DWINVER=0x0601",
                "-D_WIN32_WINNT=0x0601",
            ])
            # Static link de la runtime MinGW : evite que l'exe demande
            # libgcc_s_seh-1.dll / libstdc++-6.dll / libwinpthread-1.dll sur
            # la machine cible. Sans ca les testeurs ont une erreur
            # "libgccXXX.dll manquant" au premier lancement.
            ldflags(["--target=x86_64-w64-windows-gnu"])

    else:
        # Cross-compilation Windows depuis Linux/WSL2:
        # 1) Préfère llvm-mingw (clang/clang++).
        # 2) Fallback MinGW GCC si clang n'est pas disponible.
        _mingw_clang   = shutil.which("x86_64-w64-mingw32-clang")
        _mingw_clangxx = shutil.which("x86_64-w64-mingw32-clang++")
        _mingw_gcc     = shutil.which("x86_64-w64-mingw32-gcc")
        _mingw_gxx     = shutil.which("x86_64-w64-mingw32-g++")
        _llvm_ar       = shutil.which("llvm-ar")
        _mingw_ar      = shutil.which("x86_64-w64-mingw32-ar")

        if _mingw_clangxx:
            with toolchain(TC_WINDOWS, "clang"):
                settarget("Windows", "x86_64", "mingw")
                targettriple("x86_64-w64-windows-gnu")
                ccompiler(_mingw_clang or "x86_64-w64-mingw32-clang")
                cppcompiler(_mingw_clangxx)
                linker(_mingw_clangxx)
                if _llvm_ar:
                    archiver(_llvm_ar)
                elif _mingw_ar:
                    archiver(_mingw_ar)
                cflags([
                    "--target=x86_64-w64-windows-gnu",
                    "-DWINVER=0x0601",
                    "-D_WIN32_WINNT=0x0601",
                ])
                cxxflags([
                    "--target=x86_64-w64-windows-gnu",
                    "-DWINVER=0x0601",
                    "-D_WIN32_WINNT=0x0601",
                ])
                # Static link de la runtime MinGW (voir bloc Windows natif).
                ldflags([
                    "--target=x86_64-w64-windows-gnu",
                    "-static-libgcc",
                    "-static-libstdc++",
                    "-static",
                    "-Wl,-Bstatic", "-lpthread",
                ])
        elif _mingw_gxx:
            with toolchain(TC_WINDOWS, "gcc"):
                settarget("Windows", "x86_64", "mingw")
                ccompiler(_mingw_gcc or "x86_64-w64-mingw32-gcc")
                cppcompiler(_mingw_gxx)
                linker(_mingw_gxx)
                archiver(_mingw_ar or "x86_64-w64-mingw32-ar")
                cflags([
                    "-DWINVER=0x0601",
                    "-D_WIN32_WINNT=0x0601",
                ])
                cxxflags([
                    "-DWINVER=0x0601",
                    "-D_WIN32_WINNT=0x0601",
                ])

    emscriptenfullscreenshell(True)

    # androidsdkpath(os.getenv("ANDROID_SDK_ROOT", ""))
    # androidndkpath(os.getenv("ANDROID_NDK_ROOT", os.getenv("ANDROID_NDK_HOME", "")))

    # ── Android SDK/NDK paths (from environment) ─────────────────────────
    androidsdkpath(os.getenv("ANDROID_SDK_ROOT", ""))
    androidndkpath(os.getenv("ANDROID_NDK_ROOT", ""))