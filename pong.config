# Pong Ultra Arena - config dynamique du backend graphique.
# Valeurs : opengl | vulkan | dx11 | dx12 | software | auto.
# Editable a la main. Re-lue a chaque ouverture du jeu.
backend=vulkan
# debug=1 : active la validation GPU du backend (debug layer
# DX11/DX12, validation layers Vulkan) -> messages dans le log.
debug=0