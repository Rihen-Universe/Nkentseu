#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
NKCanvas — runtime context system (C++17)
==========================================
Contient le système complet de contextes graphiques/compute.
"""

from Jenga import *
from jengaconfig import *

import os
import shutil
import subprocess

def _pkg_exists(pkg_name: str) -> bool:
    if not shutil.which("pkg-config"):
        return False
    try:
        return subprocess.call(
            ["pkg-config", "--exists", pkg_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ) == 0
    except Exception:
        return False

def _norm(path: str) -> str:
    return path.replace("\\", "/") if path else path

_HAS_LIBDECOR = _pkg_exists("libdecor-0")
_WAYLAND_LINKS = ["pthread", "wayland-client", "xkbcommon", "wayland-cursor", "EGL", "GLESv2"]
_WAYLAND_TEST_LINKS = ["pthread", "wayland-client", "xkbcommon", "EGL", "GLESv2"]
_WAYLAND_DEFINES = ["NKENTSEU_FORCE_WINDOWING_WAYLAND_ONLY"]
if _HAS_LIBDECOR:
    _WAYLAND_LINKS.append("decor-0")
    _WAYLAND_TEST_LINKS.append("decor-0")
    _WAYLAND_DEFINES.append("NKENTSEU_WAYLAND_LIBDECOR")

_VULKAN_SDK = _norm(os.getenv("VULKAN_SDK", ""))
_VULKAN_INCLUDE = _norm(os.path.join(_VULKAN_SDK, "Include")) if _VULKAN_SDK else ""
_VULKAN_LIB = _norm(os.path.join(_VULKAN_SDK, "Lib")) if _VULKAN_SDK else ""
_VULKAN_OPT = os.getenv("NK_ENABLE_VULKAN", "auto").strip().lower()
if _VULKAN_OPT in ("0", "false", "off", "no"):
    _WANT_VULKAN = False
elif _VULKAN_OPT in ("1", "true", "on", "yes"):
    _WANT_VULKAN = True
else:
    _WANT_VULKAN = bool(_VULKAN_INCLUDE) or _pkg_exists("vulkan")

# Le backend Vulkan n'est defini QUE sur les plateformes ou il est cable+linke
# (Windows / Linux / Android / HarmonyOS). Sur Web/macOS/iOS/UWP/Xbox il reste a 0
# (pas de NkVulkanContext) -> sinon undefined symbol au link des consommateurs.
_VK_ON  = f"NKENTSEU_ENABLE_VULKAN_BACKEND={1 if _WANT_VULKAN else 0}"
_VK_OFF = "NKENTSEU_ENABLE_VULKAN_BACKEND=0"

with project("NKCanvas"):
    language("C++")
    cppdialect("C++17")
    location(".")

    # ── Dependances (mode LIB) : kindexport(NKENTSEU_CANVAS) + includedirs +
    # dependson + defines(_STATIC_LIB) resolus depuis le registre. On ne linke PAS
    # les deps NK (juste dependson). Les externals/SDK propres passent inline.
    _canvasDeps = ["NKWindow", "NKFont", "NKImage", "NKStream", "NKTime", "NKGlad", "NKThreading"]
    # NKENTSEU_ENABLE_VULKAN_BACKEND est defini par plateforme (filtres ci-dessous),
    # pas globalement : Web/macOS/iOS/UWP/Xbox n'ont pas de backend Vulkan.
    #
    # Glad : choix utilisateur via NK_USE_GLAD (env "auto/on/off"). Le "no glad" n'est plus
    # force globalement ; il est decide PAR PLATEFORME (filtres ci-dessous) :
    #   - Linux (xlib/xcb/wayland) -> glad PAR DEFAUT (NKGlad ; evite les conflits d'en-tetes
    #     GL systeme + macros X11). Le loader glad est cable dans NkOpenGLContext.
    #   - Autres (Windows/Android/Web/Harmony/...) -> chargement manuel PAR DEFAUT (fonctionnel).
    #   - NK_USE_GLAD=on/off force le meme mode partout.
    # NK_NO_GLAD2 defini == "ne PAS utiliser glad" (chargement manuel/systeme).
    _GLAD_OPT     = os.getenv("NK_USE_GLAD", "auto").strip().lower()
    _GLAD_ENV_ON  = _GLAD_OPT in ("1", "true", "on", "yes")
    _GLAD_ENV_OFF = _GLAD_OPT in ("0", "false", "off", "no")
    _GLAD_DEF_LINUX = [] if not _GLAD_ENV_OFF else ["NK_NO_GLAD2"]   # glad sauf si env=off
    _GLAD_DEF_OTHER = [] if _GLAD_ENV_ON      else ["NK_NO_GLAD2"]   # manuel sauf si env=on
    _canvasDefines = []  # NK_NO_GLAD2 ajoute par plateforme via les listes ci-dessus
    # NKUI integre (backend NkUICanvasBackend) — optionnel (flag NK_CANVAS_NKUI via
    # config/graphics.jenga -> USE_CANVAS_NKUI). Off => NKCanvas ne lie pas NKUI et
    # NkUICanvasBackend.cpp compile a vide.
    if USE_CANVAS_NKUI:
        _canvasDeps.append("NKUI")
        _canvasDefines.append("NK_CANVAS_WITH_NKUI=1")
    nkentseudependson(
        _canvasDeps,
        selfexport="NKCanvas",
        extra_includes=["src"] + ([_VULKAN_INCLUDE] if _VULKAN_INCLUDE else []),
        extra_defines=_canvasDefines,
    )

    files([
        "src/NKCanvas/**.cpp",
        "src/NKCanvas/**.h",
    ])

    objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
    targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}")

    with filter("system:Windows && options:windows-runtime=uwp"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-uwp/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-uwp")

    # ===== Windows ================================================================
    with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
        usetoolchain(TC_WINDOWS)
        defines([
            "WIN32_LEAN_AND_MEAN",
            _VK_ON,
        ] + _GLAD_DEF_OTHER)
        if _VULKAN_LIB:
            libdirs([_VULKAN_LIB])
        # Backends graphiques toujours linkes sur Windows desktop :
        #   - gdi32/user32 : Software (BitBlt) + Window infrastructure
        #   - d3d11/d3d12/dxgi/dxguid : DirectX 11 + 12 backends Renderer2D
        #     (les .cpp dans Backend/DirectX/ etaient deja compiles, mais sans
        #      les .lib correspondantes, les .exe consommateurs avaient des
        #      "undefined reference to D3D11CreateDevice / CreateDXGIFactory1"
        #      des qu'ils referencaient un symbole DX. Maintenant linkes par defaut.)
        #   - vulkan-1 : optionnel via NK_ENABLE_VULKAN ou VULKAN_SDK detecte.
        _WIN_LINKS = ["gdi32", "user32", "d3d11", "d3d12", "dxgi", "dxguid"]
        if _WANT_VULKAN:
            _WIN_LINKS.append("vulkan-1")
        links(_WIN_LINKS)

    # ===== UWP ====================================================================
    with filter("system:UWP || system:Windows && options:windows-runtime=uwp"):
        usetoolchain("xbox-clang")
        defines(["NKENTSEU_PLATFORM_UWP", _VK_OFF] + _GLAD_DEF_OTHER)
        links(["d3d12", "dxgi", "dxguid", "windowsapp"])

    # ===== Linux XLib =============================================================
    with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
        links(["X11", "Xext", "GL"])
        defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY", _VK_ON] + _GLAD_DEF_LINUX)
        if _WANT_VULKAN:
            links(["vulkan"])

    # ===== Linux headless =========================================================
    with filter("system:Linux && options:linux-backend=headless || system:Linux && options:headless"):
        defines(["NKENTSEU_FORCE_WINDOWING_NOOP_ONLY", _VK_OFF] + _GLAD_DEF_OTHER)

    # ===== Linux XCB ==============================================================
    with filter("system:Linux && options:linux-backend=xcb"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-xcb")
        links(["xcb", "xcb-image", "X11", "Xext", "GL"])
        defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY", _VK_ON] + _GLAD_DEF_LINUX)
        if _WANT_VULKAN:
            links(["vulkan"])

    # ===== Linux Wayland ==========================================================
    with filter("system:Linux && options:linux-backend=wayland"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-wayland")
        defines(_WAYLAND_DEFINES + [_VK_ON] + _GLAD_DEF_LINUX)
        links(_WAYLAND_LINKS)
        if _WANT_VULKAN:
            links(["vulkan"])

    # ===== macOS ==================================================================
    with filter("system:macOS"):
        usetoolchain("clang-native")
        defines([_VK_OFF] + _GLAD_DEF_OTHER)
        frameworks(["Metal", "QuartzCore"])

    # ===== Android ================================================================
    with filter("system:Android"):
        usetoolchain("android-ndk")
        defines([_VK_ON] + _GLAD_DEF_OTHER)
        _ANDROID_LINKS = ["android", "EGL", "GLESv3"]
        if _WANT_VULKAN:
            _ANDROID_LINKS.append("vulkan")
        links(_ANDROID_LINKS)

    # ===== HarmonyOS ==============================================================
    with filter("system:HarmonyOS"):
        # PCH desactive (NDK OHOS clang, meme contrainte qu'Android).
        pchheader("")
        pchsource("")
        usetoolchain("ohos-ndk")
        defines([_VK_ON] + _GLAD_DEF_OTHER)
        _HARMONY_LINKS = ["hilog_ndk.z", "EGL", "GLESv3"]
        if _WANT_VULKAN:
            _HARMONY_LINKS.append("vulkan")
        links(_HARMONY_LINKS)

    # ===== iOS ====================================================================
    with filter("system:iOS"):
        defines([_VK_OFF] + _GLAD_DEF_OTHER)
        frameworks(["Metal", "QuartzCore"])

    # ===== Web ====================================================================
    with filter("system:Web"):
        usetoolchain("emscripten")
        defines([_VK_OFF] + _GLAD_DEF_OTHER)

    # ===== Xbox ===================================================================
    with filter("system:XboxSeries || system:XboxOne"):
        usetoolchain("xbox-clang")
        defines([_VK_OFF] + _GLAD_DEF_OTHER)

    with filter("config:Debug"):
        defines(["_DEBUG", "DEBUG"])
        optimize("Off")
        symbols(True)
    with filter("config:Release"):
        defines(["NDEBUG"])
        optimize("Speed")
        symbols(False)

    # Tests unitaires/benchmarks (desktop uniquement)
    with filter("(system:Linux || system:macOS || (system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne)) && !system:Android && !system:iOS && !system:Web"):
        with test():
            testfiles(["tests/**.cpp"])
            # Ensure static link resolution for symbols pulled from NKWindow.
            links(["NKCanvas", "NKWindow", "NKTime"])
            with filter("system:Linux && options:linux-backend=wayland"):
                defines(_WAYLAND_DEFINES)
                links(_WAYLAND_TEST_LINKS)
            with filter("system:Linux && options:linux-backend=xcb"):
                defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])
                links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11-xcb", "xkbcommon", "xkbcommon-x11", "Xext"])
            with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
                defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])
                links(["pthread", "X11", "Xext"])
            with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
                if _VULKAN_LIB:
                    libdirs([_VULKAN_LIB])
                links([
                    "user32", "gdi32", "opengl32", "dwmapi", "shell32",
                    "mf", "mfplat", "mfreadwrite", "mfuuid",
                    "uuid", "ole32", "dinput8",
                    "d3d11", "d3d12", "dxgi", "dxguid",
                    "vulkan-1"
                ])
