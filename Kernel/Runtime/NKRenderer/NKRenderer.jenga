#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
NKRenderer - Runtime renderer module (multi-API ready, C++17)
==============================================================
Module prepared for future renderer
keeps the current production context system.
"""

from Jenga import *
from jengaconfig import *

# Vars graphiques/Wayland partagees : config/graphics.jenga + config/wayland.jenga
# (VULKAN_INCLUDE/LIB, WANT_VULKAN, USE_NKGLAD, WAYLAND_*).

with project("NKRenderer"):
    language("C++")
    cppdialect("C++17")
    location(".")

    pchheader("pch/pch.h")
    pchsource("pch/pch.cpp")

    # Dependances (mode lib) : kindexport(NKENTSEU_RENDERER) + src/pch + includedirs +
    # dependson + defines _STATIC_LIB auto (dont NKENTSEU_SERIALIZATION_STATIC_LIB,
    # NKSerialization etant une dep). NKRHI/pch + Vulkan SDK en extra (specifiques).
    rendererDeps = ["NKMath", "NKTime", "NKLogger", "NKEvent", "NKWindow", "NKContainers",
                    "NKMemory", "NKCore", "NKPlatform", "NKThreading", "NKRHI", "NKSL",
                    "NKFont", "NKImage", "NKStream", "NKFileSystem", "NKSerialization", "NKReflection"]
    if USE_NKGLAD:
        rendererDeps.append("NKGlad")
    rendererDefines = [
        f"NKRENDERER_USE_NKGLAD={1 if USE_NKGLAD else 0}",
        f"NKENTSEU_ENABLE_VULKAN_BACKEND={1 if WANT_VULKAN else 0}",
    ]
    if WANT_VULKAN:
        rendererDefines.append("NK_RHI_VK_ENABLED")
    nkentseudependson(
        rendererDeps,
        selfexport="NKRenderer",
        extra_includes=["%{wks.location}/Externals", "%{NKRHI.location}/pch"]
                       + ([VULKAN_INCLUDE] if VULKAN_INCLUDE else []),
        extra_defines=rendererDefines,
    )

    files([
        "src/NKRenderer/**.cpp",
        "src/NKRenderer/**.h",
    ])

    objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
    targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}")

    with filter("system:Windows && options:windows-runtime=uwp"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-uwp/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-uwp")

    with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
        usetoolchain(TC_WINDOWS)
        defines(["WIN32_LEAN_AND_MEAN", "NK_RHI_DX11_ENABLED", "NK_RHI_DX12_ENABLED"])
        if VULKAN_LIB:
            libdirs([VULKAN_LIB])
        _WIN_LINKS = [
            "gdi32", "user32", "opengl32", "dwmapi", "shell32",
            "d3d11", "d3d12", "dxgi", "dxguid", "d3dcompiler",
            "uuid", "ole32",
        ]
        if WANT_VULKAN:
            _WIN_LINKS.append("vulkan-1")
        links(_WIN_LINKS)

    with filter("system:UWP || system:Windows && options:windows-runtime=uwp"):
        usetoolchain("xbox-clang")
        defines(["NKENTSEU_PLATFORM_UWP"])
        links(["d3d12", "dxgi", "dxguid", "windowsapp"])

    with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
        links(["pthread", "X11", "Xext", "GL"])
        defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])
        if WANT_VULKAN:
            links(["vulkan"])

    with filter("system:Linux && options:linux-backend=headless || system:Linux && options:headless"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-headless")
        defines(["NKENTSEU_FORCE_WINDOWING_NOOP_ONLY"])
        links(["pthread"])

    with filter("system:Linux && options:linux-backend=xcb"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-xcb")
        links(["pthread", "xcb", "xcb-image", "X11", "Xext", "GL"])
        defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])
        if WANT_VULKAN:
            links(["vulkan"])

    with filter("system:Linux && options:linux-backend=wayland"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-wayland")
        defines(WAYLAND_DEFINES)
        links(WAYLAND_LINKS)
        if WANT_VULKAN:
            links(["vulkan"])

    with filter("system:macOS"):
        usetoolchain("clang-native")
        frameworks(["Cocoa", "QuartzCore", "OpenGL", "Metal"])

    with filter("system:Android"):
        usetoolchain("android-ndk")
        _ANDROID_LINKS = ["android", "log", "EGL", "GLESv3"]
        if WANT_VULKAN:
            _ANDROID_LINKS.append("vulkan")
        links(_ANDROID_LINKS)

    # ===== HarmonyOS ==============================================================
    with filter("system:HarmonyOS"):
        # PCH desactive (NDK OHOS clang, meme contrainte qu'Android).
        pchheader("")
        pchsource("")
        usetoolchain("ohos-ndk")
        _HARMONY_LINKS = ["hilog_ndk.z", "EGL", "GLESv3"]
        if WANT_VULKAN:
            _HARMONY_LINKS.append("vulkan")
        links(_HARMONY_LINKS)

    with filter("system:iOS"):
        frameworks(["UIKit", "QuartzCore", "OpenGLES", "Metal"])

    with filter("system:Web"):
        usetoolchain("emscripten")

    with filter("system:XboxSeries || system:XboxOne"):
        usetoolchain("xbox-clang")
        links(["d3d12", "dxgi", "dxguid", "xgameruntime"])

    with filter("config:Debug"):
        defines(["_DEBUG", "DEBUG"])
        optimize("Off")
        symbols(True)

    with filter("config:Release"):
        defines(["NDEBUG"])
        optimize("Speed")
        symbols(False)

    with filter("(system:Linux || system:macOS || (system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne)) && !system:Android && !system:iOS && !system:Web"):
        with test():
            testfiles(["tests/**.cpp"])
            _TEST_LINKS = ["NKRenderer", "NKCanvas", "NKWindow", "NKTime"]
            if USE_NKGLAD:
                _TEST_LINKS.append("NKGlad")
            links(_TEST_LINKS)
            with filter("system:Linux && options:linux-backend=wayland"):
                defines(WAYLAND_DEFINES)
                links(WAYLAND_TEST_LINKS)
            with filter("system:Linux && options:linux-backend=xcb"):
                defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])
                links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11-xcb", "xkbcommon", "xkbcommon-x11", "Xext"])
            with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
                defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])
                links(["pthread", "X11", "Xext"])
            with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
                if VULKAN_LIB:
                    libdirs([VULKAN_LIB])
                _WIN_TEST_LINKS = [
                    "user32", "gdi32", "opengl32", "dwmapi", "shell32",
                    "d3d11", "d3d12", "dxgi", "dxguid", "d3dcompiler",
                    "uuid", "ole32",
                ]
                if WANT_VULKAN:
                    _WIN_TEST_LINKS.append("vulkan-1")
                links(_WIN_TEST_LINKS)
