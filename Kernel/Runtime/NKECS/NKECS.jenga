#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
NKECS — Entity-Component-System bas niveau à archétypes (C++17)
==============================================================
Moteur ECS zero-STL, stockage dense par archétypes (combinaisons de
composants), graphe de transition mis en cache et requêtes typées.

Contenu (src/NKECS/) :
  NkECSDefines.h               => Types/constantes de base (NkEntityId, masques)
  Core/NkTypeRegistry.h/cpp    => Registre global des types de composants
  Storage/NkComponentPool.h    => Stockage dense des données de composants
  Storage/NkArchetype.h        => Archétypes (combinaisons de composants)
  Storage/NkArchetypeGraph.h   => Graphe de transition entre archétypes
  System/NkSystem.h            => Interface de base des systèmes
  System/NkScheduler.*         => Ordonnanceur (DAG de dépendances)
  World/NkWorld.h/cpp          => Conteneur principal des entités/systèmes
  Query/NkQuery.h              => Interrogation des entités par composants
  Events/NkGameplayEventBus.h  => Bus d'événements gameplay
  Reflect/NkReflect*.h/cpp     => Pont réflexion (NkReflectBridge) + sérialisation
"""

from Jenga import *
from jengaconfig import *

with project("NKECS"):
    language("C++")
    cppdialect("C++17")
    location(".")

    nkentseudependson(
        # NKReflection + NKSerialization (couche System) : pont reflexion P4.
        # NKECS (Runtime) -> NKReflection/NKSerialization (System) = OK, pas de cycle.
        ["NKPlatform", "NKCore", "NKMemory", "NKMath", "NKContainers", "NKThreading", "NKLogger",
         "NKReflection", "NKSerialization"],
        selfexport="NKECS",
        extra_includes=["src"],
    )

    files([
        # Fondations
        "src/**.cpp"
    ])

    objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
    targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}")

    with filter("system:Windows && options:windows-runtime=uwp"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-uwp/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-uwp")

    # ===== Windows ================================================================
    with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
        usetoolchain(TC_WINDOWS)
        defines([
            "WIN32_LEAN_AND_MEAN",
            "_UNICODE",
            "UNICODE",
        ])

    # ===== Linux ==================================================================
    with filter("system:Linux && options:linux-backend=headless || system:Linux && options:headless"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-headless")

    with filter("system:Linux && options:linux-backend=xcb"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-xcb")

    with filter("system:Linux && options:linux-backend=wayland"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-wayland")

    with filter("system:Linux"):
        links(["pthread"])

    # ===== macOS ==================================================================
    with filter("system:macOS"):
        usetoolchain("clang-native")

    # ===== Android ================================================================
    with filter("system:Android"):
        usetoolchain("android-ndk")
        links(["android", "log"])
        androidminsdk(21)
        androidtargetsdk(34)
        androidcompilesdk(34)
        androidabis(["armeabi-v7a", "arm64-v8a", "x86", "x86_64"])

    # ===== HarmonyOS ==============================================================
    with filter("system:HarmonyOS"):
        # PCH desactive (NDK OHOS clang, meme contrainte qu'Android).
        pchheader("")
        pchsource("")
        usetoolchain("ohos-ndk")
        links(["hilog_ndk.z"])

    # ===== iOS ====================================================================
    with filter("system:iOS"):
        iosminsdk("13.0")

    # ===== Web ====================================================================
    with filter("system:Web"):
        usetoolchain("emscripten")

    # ===== UWP ====================================================================
    with filter("system:UWP || system:Windows && options:windows-runtime=uwp"):
        usetoolchain("xbox-clang")
        defines(["NKENTSEU_PLATFORM_UWP"])
        links(["windowsapp"])

    # ===== Xbox ===================================================================
    with filter("system:XboxSeries || system:XboxOne"):
        usetoolchain("xbox-clang")
        defines(["NKENTSEU_PLATFORM_XBOX"])

    with filter("config:Debug"):
        defines(["_DEBUG", "DEBUG"])
        optimize("Off")
        symbols(True)
    with filter("config:Release"):
        defines(["NDEBUG"])
        optimize("Speed")
        symbols(False)

    # Tests unitaires (desktop uniquement)
    with filter("(system:Linux || system:macOS || (system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne)) && !system:Android && !system:iOS && !system:Web"):
        with test():
            testfiles(["tests/**.cpp"])
            links([
                "NKECS",
                "NKReflection",
                "NKSerialization",
                "NKThreading",
                "NKContainers",
                "NKCore",
                "NKMemory",
                "NKLogger",
                "NKMath",
                "NKPlatform",
            ])
